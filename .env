# ─────────────────────────────────────────────────────────────
# USERBOT РАССЫЛЬЩИК — файл окружения (.env)
# ─────────────────────────────────────────────────────────────
# Не передавайте этот файл третьим лицам и не загружайте в Git!
# Добавьте .env в .gitignore.
# ─────────────────────────────────────────────────────────────


# ── Telegram API ──────────────────────────────────────────────
# Получить на https://my.telegram.org → «API development tools»
# Войдите под своим номером телефона, создайте приложение —
# любое название, платформа Other, URL можно оставить пустым.

API_ID=33954207                      # числовой ID (пример: 12345678)
API_HASH=c63065a328bcf9c44d9a88d21b90aa81  # строка из 32 символов


# ── Сессия ────────────────────────────────────────────────────
# Имя файла сессии (без расширения .session).
# Pyrogram создаст файл <SESSION_NAME>.session рядом со скриптом.
# Можно оставить как есть.

SESSION_NAME=userbot_session


# ── Задержки между сообщениями (секунды) ─────────────────────
# Чем больше диапазон — тем менее предсказуемо поведение бота,
# тем ниже риск блокировки. Не ставьте меньше 60 секунд.

DELAY_MIN=8     # минимальная пауза (~10 секунд)
DELAY_MAX=12    # максимальная пауза (~10 секунд)


# ── Задержки после вступления в чат (секунды) ─────────────────
# Пауза между командой «вступить» и первым сообщением в чат.

JOIN_DELAY_MIN=15
JOIN_DELAY_MAX=45


# ── База данных ───────────────────────────────────────────────
# Путь к SQLite-файлу. Можно указать абсолютный путь,
# например: /home/user/bots/sender.db

DB_PATH=sender.db

# Telegram bot control
BOT_TOKEN=8607033756:AAHkqkUBvFz7pbuI0xn3emTjVIvXzxaFTXE
ADMIN_IDS=8500766185

